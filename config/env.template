# Pi Agent Suite — Environment Variables Template
#
# Copy this file and fill in your values:
#   cp config/env.template ~/.pi/env.sh   (Linux/macOS)
#   cp config/env.template ~/.pi/env.ps1  (Windows — change syntax below)
#
# Then add to your shell profile:
#   echo 'source ~/.pi/env.sh' >> ~/.bashrc   (Linux/macOS)
#   echo '. ~/.pi/env.ps1' >> $PROFILE        (Windows PowerShell)
#
# IMPORTANT: Never commit this file with real API keys.

# ─── Pi Agent ─────────────────────────────────────────────────────────────────
export PI_AGENT_HOME="$HOME/.pi"

# ─── MemPalace ────────────────────────────────────────────────────────────────
export MEMPALACE_PALACE="$HOME/.mempalace/palace"

# How often to auto-mine (in conversation exchanges). Default: 15
# export MEMPAL_SAVE_INTERVAL=15

# Extra directory to mine on every Stop event (optional)
# export MEMPAL_INGEST_DIR="$HOME/your-project"

# ─── MiniMax (default provider) ───────────────────────────────────────────────
# Get your API key from: https://www.minimaxi.com/user-center/basic-information/interface-key
export MINIMAX_API_KEY="your-minimax-api-key-here"

# MiniMax group ID (shown in your account dashboard)
export MINIMAX_GROUP_ID="your-group-id-here"

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
# export ANTHROPIC_API_KEY="your-anthropic-key-here"

# ─── OpenAI (optional) ────────────────────────────────────────────────────────
# export OPENAI_API_KEY="your-openai-key-here"

# ─── Google Gemini (optional) ─────────────────────────────────────────────────
# export GEMINI_API_KEY="your-gemini-key-here"

# ─── Obsidian (optional) ──────────────────────────────────────────────────────
# Path to your Obsidian vault directory
# export OBSIDIAN_VAULT="$HOME/YourVaultName"

# API key from Obsidian Local REST API plugin settings
# export OBSIDIAN_API_KEY="your-obsidian-api-key-here"

# Your vault name as shown in Obsidian
# export OBSIDIAN_VAULT_NAME="YourVaultName"
